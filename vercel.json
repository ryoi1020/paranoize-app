{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/cards", "destination": "/pages/cards.html" },
    { "source": "/reika", "destination": "/pages/reika.html" },
    { "source": "/tasks", "destination": "/pages/tasks.html" },
    { "source": "/memo", "destination": "/pages/memo.html" },
    { "source": "/board", "destination": "/pages/board.html" },
    { "source": "/formation", "destination": "/pages/formation.html" },
    { "source": "/(.*)", "destination": "/pages/index.html" }
  ]
}
